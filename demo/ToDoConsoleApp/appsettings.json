{
  "ConnectionStrings": {
    "DefaultConnection": "Server=*****; Database=*****; User Id=*****; Password=*****; Encrypt=True; TrustServerCertificate=True; MultipleActiveResultSets=True; "
  },
  "AlwaysEncrypt": {
    "Enabled": true,
    "CertificatePath": "[CERTIFICATE_PATH]",
    "CertificatePassword": "[CERTIFICATE_PWD]"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "Console": {
      "IncludeScopes": true,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss"
    }
  },
  "ApplicationSettings": {
    "PreferEmbeddedSqlScripts": true,
    "EnableScriptCaching": true,
    "CommandTimeout": 30
  }
}